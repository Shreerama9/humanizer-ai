# ── Model serving ─────────────────────────────────────────────────────────────
MODEL_PATH=models/humanizer-llama3-8b-merged
USE_4BIT=true
MAX_NEW_TOKENS=2048

# ── API server ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS (use * only in development)
CORS_ORIGINS=http://localhost:3000

# ── Dataset generation ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Experiment tracking ────────────────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=humanizer-ai

# ── UI ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
